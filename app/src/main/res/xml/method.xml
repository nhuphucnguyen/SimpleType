<?xml version="1.0" encoding="utf-8"?>
<!-- Input-method metadata: declares the EN and VI keyboard subtypes the globe key cycles. -->
<input-method xmlns:android="http://schemas.android.com/apk/res/android"
    android:settingsActivity="dev.phucngu.simpletype.ui.SettingsActivity"
    android:supportsSwitchingToNextInputMethod="true">

    <subtype
        android:icon="@mipmap/ic_launcher"
        android:label="@string/subtype_en"
        android:imeSubtypeLocale="en_US"
        android:imeSubtypeMode="keyboard"
        android:isAsciiCapable="true" />

    <subtype
        android:icon="@mipmap/ic_launcher"
        android:label="@string/subtype_vi"
        android:imeSubtypeLocale="vi_VN"
        android:imeSubtypeMode="keyboard" />
</input-method>
