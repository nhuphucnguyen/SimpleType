<?xml version="1.0" encoding="utf-8"?>
<!-- Root view returned by SimpleTypeIME.onCreateInputView: a top toolbar (menu · suggestions ·
     mic) above the keys. The bottom hide-keyboard and language/globe controls are provided by
     the system navigation bar, so we don't draw our own (which would duplicate them). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/kb_background"
    android:clipToPadding="false"
    android:paddingBottom="@dimen/kb_bottom_padding">

    <!-- Top toolbar: menu pinned left, mic pinned right, suggestion/status area between. -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/kb_toolbar_height"
        android:paddingStart="6dp"
        android:paddingEnd="10dp">

        <LinearLayout
            android:id="@+id/toolbar_options_container"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/kb_toolbar_height"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:animateLayoutChanges="true">

            <ImageButton
                android:id="@+id/toolbar_menu"
                android:layout_width="@dimen/kb_toolbar_height"
                android:layout_height="@dimen/kb_toolbar_height"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_kb_menu"
                android:scaleType="fitCenter"
                android:padding="7dp"
                android:tint="@color/kb_chrome_icon"
                android:contentDescription="@string/toolbar_menu" />

            <ImageButton
                android:id="@+id/toolbar_setup"
                android:layout_width="@dimen/kb_toolbar_height"
                android:layout_height="@dimen/kb_toolbar_height"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_kb_settings"
                android:scaleType="fitCenter"
                android:padding="7dp"
                android:tint="@color/kb_chrome_icon"
                android:visibility="gone"
                android:contentDescription="@string/settings_title" />

            <ImageButton
                android:id="@+id/toolbar_clipboard"
                android:layout_width="@dimen/kb_toolbar_height"
                android:layout_height="@dimen/kb_toolbar_height"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_kb_clipboard"
                android:scaleType="fitCenter"
                android:padding="7dp"
                android:tint="@color/kb_chrome_icon"
                android:visibility="gone"
                android:contentDescription="@string/key_clipboard" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/toolbar_mic"
            android:layout_width="@dimen/kb_toolbar_mic_size"
            android:layout_height="@dimen/kb_toolbar_mic_size"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_kb_circle"
            android:src="@drawable/ic_kb_mic"
            android:scaleType="centerInside"
            android:padding="7dp"
            android:tint="@color/kb_chrome_icon"
            android:contentDescription="@string/toolbar_mic" />

        <!-- Suggestion chips will live here later; also hosts the voice status text. -->
        <TextView
            android:id="@+id/voice_status"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toEndOf="@id/toolbar_options_container"
            android:layout_toStartOf="@id/toolbar_mic"
            android:gravity="center"
            android:textColor="@color/kb_status_text"
            android:textSize="13sp"
            android:text=""
            tools:ignore="UnusedAttribute" />
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <dev.phucngu.simpletype.ime.LatinKeyboardView
            android:id="@+id/keyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/clipboard_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@color/kb_background">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="@string/clipboard_title"
                    android:textColor="@color/kb_status_text"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/clipboard_close"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_kb_backspace"
                    android:rotation="180"
                    android:scaleType="centerInside"
                    android:tint="@color/kb_chrome_icon"
                    android:contentDescription="@string/clipboard_close" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/clipboard_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:overScrollMode="never" />

        </LinearLayout>
    </FrameLayout>
</LinearLayout>
