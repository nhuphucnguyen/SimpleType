<?xml version="1.0" encoding="utf-8"?>
<!-- Root view returned by SimpleTypeIME.onCreateInputView: M3 Expressive toolbar, keys,
     and clipboard sheet. The system IME navigation area provides hide/globe controls. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_kb_root"
    android:clipToOutline="true"
    android:clipToPadding="false"
    android:paddingBottom="@dimen/kb_bottom_padding">

    <!-- Top toolbar: menu pinned left, mic pinned right, suggestion/status area between. -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/kb_toolbar_height"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="2dp">

        <LinearLayout
            android:id="@+id/toolbar_options_container"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/kb_toolbar_height"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:animateLayoutChanges="true">

            <ImageButton
                android:id="@+id/toolbar_menu"
                android:layout_width="@dimen/kb_toolbar_button_size"
                android:layout_height="@dimen/kb_toolbar_button_size"
                android:background="@drawable/bg_kb_circle"
                android:src="@drawable/ic_kb_menu"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:tint="@color/kb_chrome_icon"
                android:contentDescription="@string/toolbar_menu" />

            <ImageButton
                android:id="@+id/toolbar_setup"
                android:layout_width="@dimen/kb_toolbar_button_size"
                android:layout_height="@dimen/kb_toolbar_button_size"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_kb_circle"
                android:src="@drawable/ic_kb_settings"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:tint="@color/kb_chrome_icon"
                android:visibility="gone"
                android:contentDescription="@string/settings_title" />

            <ImageButton
                android:id="@+id/toolbar_clipboard"
                android:layout_width="@dimen/kb_toolbar_button_size"
                android:layout_height="@dimen/kb_toolbar_button_size"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_kb_circle"
                android:src="@drawable/ic_kb_clipboard"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:tint="@color/kb_chrome_icon"
                android:visibility="gone"
                android:contentDescription="@string/key_clipboard" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/toolbar_mic"
            android:layout_width="@dimen/kb_toolbar_mic_size"
            android:layout_height="@dimen/kb_toolbar_mic_size"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_kb_mic"
            android:src="@drawable/ic_kb_mic"
            android:scaleType="centerInside"
            android:padding="13dp"
            android:tint="@color/kb_action_text"
            android:contentDescription="@string/toolbar_mic" />

        <!-- Suggestion chips will live here later; also hosts the voice status text. -->
        <TextView
            android:id="@+id/voice_status"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toEndOf="@id/toolbar_options_container"
            android:layout_toStartOf="@id/toolbar_mic"
            android:gravity="center"
            android:textColor="@color/kb_status_text"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text=""
            tools:ignore="UnusedAttribute" />
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <dev.phucngu.simpletype.ime.LatinKeyboardView
            android:id="@+id/keyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/clipboard_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@color/kb_background">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="@string/clipboard_title"
                    android:textColor="@color/kb_key_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/clipboard_close"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_kb_circle"
                    android:src="@drawable/ic_kb_close"
                    android:scaleType="centerInside"
                    android:padding="11dp"
                    android:tint="@color/kb_chrome_icon"
                    android:contentDescription="@string/clipboard_close" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/clipboard_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp" />

        </LinearLayout>
    </FrameLayout>

</LinearLayout>
