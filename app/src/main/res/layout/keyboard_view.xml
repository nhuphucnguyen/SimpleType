<?xml version="1.0" encoding="utf-8"?>
<!-- Root view returned by SimpleTypeIME.onCreateInputView: a top toolbar (menu · suggestions ·
     mic) above the keys. The bottom hide-keyboard and language/globe controls are provided by
     the system navigation bar, so we don't draw our own (which would duplicate them). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/kb_background"
    android:clipToPadding="false"
    android:paddingBottom="@dimen/kb_bottom_padding">

    <!-- Top toolbar: menu pinned left, mic pinned right, suggestion/status area between. -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/kb_toolbar_height"
        android:paddingStart="6dp"
        android:paddingEnd="10dp">

        <ImageButton
            android:id="@+id/toolbar_menu"
            android:layout_width="@dimen/kb_toolbar_height"
            android:layout_height="@dimen/kb_toolbar_height"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_kb_menu"
            android:scaleType="centerInside"
            android:tint="@color/kb_chrome_icon"
            android:contentDescription="@string/toolbar_menu" />

        <ImageButton
            android:id="@+id/toolbar_mic"
            android:layout_width="@dimen/kb_toolbar_mic_size"
            android:layout_height="@dimen/kb_toolbar_mic_size"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_kb_circle"
            android:src="@drawable/ic_kb_mic"
            android:scaleType="centerInside"
            android:padding="7dp"
            android:tint="@color/kb_chrome_icon"
            android:contentDescription="@string/toolbar_mic" />

        <!-- Suggestion chips will live here later; also hosts the voice status text. -->
        <TextView
            android:id="@+id/voice_status"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toEndOf="@id/toolbar_menu"
            android:layout_toStartOf="@id/toolbar_mic"
            android:gravity="center"
            android:textColor="@color/kb_status_text"
            android:textSize="13sp"
            android:text=""
            tools:ignore="UnusedAttribute" />
    </RelativeLayout>

    <dev.phucngu.simpletype.ime.LatinKeyboardView
        android:id="@+id/keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
</LinearLayout>
