<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="8dp"
    android:paddingStart="14dp"
    android:paddingTop="14dp"
    android:paddingEnd="14dp"
    android:paddingBottom="14dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_clipboard_item">

    <TextView
        android:id="@+id/item_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/kb_key_text"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.08" />

    <ImageButton
        android:id="@+id/item_pin"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="12dp"
        android:padding="10dp"
        android:background="@drawable/bg_kb_circle"
        android:src="@drawable/ic_kb_pin"
        android:scaleType="fitCenter"
        app:tint="@color/kb_chrome_icon"
        android:contentDescription="@string/clipboard_pin" />

    <ImageButton
        android:id="@+id/item_delete"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="8dp"
        android:padding="10dp"
        android:background="@drawable/bg_kb_circle"
        android:src="@drawable/ic_kb_delete"
        android:scaleType="fitCenter"
        app:tint="@color/kb_chrome_icon"
        android:contentDescription="@string/clipboard_delete" />

</LinearLayout>
