<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/item_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/kb_key_text"
        android:textSize="14sp" />

    <ImageButton
        android:id="@+id/item_pin"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_kb_pin"
        android:scaleType="centerInside"
        app:tint="@color/kb_chrome_icon"
        android:contentDescription="@string/clipboard_pin" />

    <ImageButton
        android:id="@+id/item_delete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_kb_delete"
        android:scaleType="centerInside"
        app:tint="@color/kb_chrome_icon"
        android:contentDescription="@string/clipboard_delete" />

</LinearLayout>
