<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_intro"
            android:textSize="15sp"
            android:paddingBottom="24dp" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/step_enable"
            android:textSize="15sp"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btn_enable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_enable"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/step_select"
            android:textSize="15sp"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btn_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_select"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/voice_models_title"
            android:textSize="17sp"
            android:textStyle="bold"
            android:paddingBottom="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/voice_models_intro"
            android:textSize="14sp"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/btn_model_en"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_download_en" />

        <Button
            android:id="@+id/btn_model_vi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_download_vi"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_title"
            android:textSize="17sp"
            android:textStyle="bold"
            android:paddingBottom="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_intro"
            android:textSize="14sp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/lbl_row_height"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seek_row_height"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/lbl_gap_h"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:paddingTop="8dp" />

        <SeekBar
            android:id="@+id/seek_gap_h"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/lbl_gap_v"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:paddingTop="8dp" />

        <SeekBar
            android:id="@+id/seek_gap_v"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/lbl_bottom_pad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:paddingTop="8dp" />

        <SeekBar
            android:id="@+id/seek_bottom_pad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <dev.phucngu.simpletype.ime.LatinKeyboardView
            android:id="@+id/size_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_number_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_number_row"
            android:textSize="15sp"
            android:paddingTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_number_row_desc"
            android:textSize="13sp"
            android:alpha="0.7"
            android:paddingBottom="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_symbol_hints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_symbol_hints"
            android:textSize="15sp"
            android:paddingTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_symbol_hints_desc"
            android:textSize="13sp"
            android:alpha="0.7"
            android:paddingBottom="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_dedicated_number_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_dedicated_number_row"
            android:textSize="15sp"
            android:paddingTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_dedicated_number_row_desc"
            android:textSize="13sp"
            android:alpha="0.7"
            android:paddingBottom="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_haptic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_haptic"
            android:textSize="15sp"
            android:paddingTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_haptic_desc"
            android:textSize="13sp"
            android:alpha="0.7"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/lbl_haptic_strength"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:paddingTop="4dp" />

        <SeekBar
            android:id="@+id/seek_haptic_strength"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btn_size_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/size_reset"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_try"
            android:textSize="15sp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/try_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/try_hint"
            android:inputType="textCapSentences"
            android:importantForAutofill="no"
            android:minHeight="48dp" />
    </LinearLayout>
</ScrollView>
