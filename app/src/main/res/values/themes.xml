<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SimpleType" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/m3_primary</item>
        <item name="colorOnPrimary">@color/m3_on_primary</item>
        <item name="colorPrimaryContainer">@color/m3_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/m3_on_primary_container</item>
        <item name="colorSecondaryContainer">@color/m3_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/m3_on_secondary_container</item>
        <item name="android:colorAccent">@color/m3_primary</item>
        <item name="android:navigationBarColor">@color/m3_bg</item>
        <item name="android:statusBarColor">@color/m3_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <!-- Used by MicPermissionActivity: invisible, just hosts the permission dialog. -->
    <style name="Theme.SimpleType.Transparent" parent="Theme.SimpleType">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
