<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Voice typing captures audio fully on-device; nothing leaves the phone. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SimpleType">

        <!-- Launcher / settings entry point: guides the user to enable & select SimpleType. -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Transparent activity that requests RECORD_AUDIO on behalf of the IME service,
             since a service cannot show a runtime permission dialog itself. -->
        <activity
            android:name=".ui.MicPermissionActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.SimpleType.Transparent" />

        <!-- The input method (keyboard) service. -->
        <service
            android:name=".ime.SimpleTypeIME"
            android:exported="true"
            android:label="@string/ime_label"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>
    </application>

</manifest>
